<?php
$flag = "{{ parameters['arp_flag'] }}";
$users = ["admin" => "password123", "jperez" => "empresa2024"];

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    http_response_code(403);
    echo json_encode([
        "status" => "error",
        "mensaje" => "403 - Acceso denegado. Esta area requiere credenciales corporativas validas.",
        "hint" => "El trafico de red nunca miente."
    ]);
    exit;
}

if (!isset($_POST['username']) || !isset($_POST['password'])) {
    http_response_code(403);
    echo json_encode([
        "status" => "error",
        "mensaje" => "403 - Credenciales requeridas.",
        "hint" => "El trafico de red nunca miente."
    ]);
    exit;
}

if (isset($users[$_POST['username']]) && $users[$_POST['username']] === $_POST['password']) {
    echo json_encode([
        "status" => "ok",
        "mensaje" => "Bienvenido al area restringida - Solo personal autorizado",
        "usuario" => $_POST['username'],
        "flag" => $flag
    ]);
} else {
    http_response_code(403);
    echo json_encode([
        "status" => "error",
        "mensaje" => "403 - Credenciales incorrectas.",
        "hint" => "El trafico de red nunca miente."
    ]);
}
?>
