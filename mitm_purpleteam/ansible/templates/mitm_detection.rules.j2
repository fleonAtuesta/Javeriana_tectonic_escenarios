# ============================================================
# mitm_detection.rules.j2 - Reglas MITM con flags Blue Team
# Generadas por Tectonic con flags únicas por instancia
# ============================================================

# --- ARP Spoofing -------------------------------------------
alert arp any any -> any any (msg:"MITM ARP Spoofing - Conflicto de MAC | BLUE-FLAG: {{ parameters['flags']['blue_arp_flag'] }}"; arp.opcode:2; threshold:type both, track by_src, count 10, seconds 5; classtype:network-event; sid:9000001; rev:1;)

alert arp any any -> any any (msg:"MITM ARP Gratuitous sospechoso"; arp.opcode:1; classtype:bad-unknown; priority:1; sid:9000002; rev:1;)

# --- DNS Spoofing -------------------------------------------
alert udp any 53 -> any any (msg:"MITM DNS - Respuesta fuente no autorizada | BLUE-FLAG: {{ parameters['flags']['blue_dns_flag'] }}"; classtype:bad-unknown; priority:1; sid:9000004; rev:1;)

# --- HTTP Credentials in clear ------------------------------
alert http any any -> any any (msg:"MITM HTTP Credenciales en claro | BLUE-FLAG: {{ parameters['flags']['blue_http_flag'] }}"; http.method; content:"POST"; http.request_body; content:"password"; nocase; classtype:policy-violation; priority:2; sid:9000005; rev:1;)

alert http any any -> any any (msg:"MITM HTTP Login sin TLS"; http.method; content:"POST"; http.uri; content:"login"; nocase; classtype:policy-violation; sid:9000006; rev:1;)

# --- SSL Strip ----------------------------------------------
alert http any any -> any any (msg:"MITM SSL Strip - HTTPS degradado"; http.header; content:"X-Forwarded-Proto: https"; classtype:bad-unknown; priority:1; sid:9000007; rev:1;)

# --- Reconocimiento Nmap ------------------------------------
alert tcp {{ hostvars['attacker']['ansible_host'] }} any -> any any (msg:"RED TEAM Nmap scan desde atacante"; flags:S; threshold:type both, track by_src, count 30, seconds 5; classtype:network-scan; sid:9000008; rev:1;)

# --- MitM Proxy ---------------------------------------------
alert tcp any any -> any any (msg:"MITM mitmproxy detectado"; content:"mitmproxy"; nocase; classtype:bad-unknown; sid:9000009; rev:1;)
